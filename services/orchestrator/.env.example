# Fleet Health Orchestrator Configuration
# Copy this file to .env and fill in real values for your environment

# === API Configuration ===
# API_TITLE=Fleet Health Orchestrator
# API_VERSION=0.1.0

# === CORS Configuration ===
# Leave empty for no CORS, or provide comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Database Configuration ===
# DATABASE_URL is preferred for PostgreSQL in production
# DATABASE_URL=postgresql://fleet_health:change-me@localhost:5432/fleet_health
# DATABASE_PATH is auto-generated from package structure, but can be overridden
# DATABASE_PATH=/path/to/fleet_health.db

# === Retrieval Backend Configuration ===
RETRIEVAL_BACKEND=lexical

# For S3 Vectors backend (optional):
# RETRIEVAL_BACKEND=s3vectors
# S3_VECTORS_BUCKET=my-vectors-bucket
# S3_VECTORS_INDEX=my-index
# S3_VECTORS_EMBEDDING_DIMENSION=3072
# S3_VECTORS_QUERY_VECTOR_JSON=[]

# === Embedding Configuration ===
EMBEDDING_PROVIDER=hash
# Options: hash, openai, http, sentence_transformers

# Add OPENAI_API_KEY to auto-enable OpenAI-backed diagnosis/planning helpers.
# When OPENAI_API_KEY is present and EMBEDDING_PROVIDER is left as hash, the
# orchestrator prefers OpenAI embeddings automatically.
# OPENAI_API_KEY=sk_test_...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# === LLM Enrichment (optional) ===
# Enable LLM-assisted summary refinement (requires OPENAI_API_KEY).
# If omitted, the orchestrator will still use OpenAI when the key is present.
# LLM_REPORT_REFINE_ENABLED=false
# LLM_REPORT_MODEL=gpt-5.4-mini

# Enable LLM-assisted diagnosis hypothesis enrichment (requires OPENAI_API_KEY)
# LLM_DIAGNOSIS_ENRICH_ENABLED=false
# LLM_DIAGNOSIS_MODEL=gpt-5.4-mini

# === LLM Chat Orchestration (optional) ===
# Enable OpenAI-generated chat answers and MCP-style tool execution.
# LLM_CHAT_ENABLED=true
# LLM_CHAT_MODEL=gpt-5.4-mini
# LLM_CHAT_TEMPERATURE=0.2
# LLM_CHAT_MAX_OUTPUT_TOKENS=600

# MCP tool execution controls for chat.
# CHAT_TOOL_TIMEOUT_SECONDS=8
# CHAT_TOOL_MAX_CALLS_PER_TURN=8

# Transport mode for chat tool calls:
# - local: in-process repository/retrieval tool execution
# - http_json: call remote HTTP JSON API endpoints
# CHAT_TOOL_TRANSPORT=local
# CHAT_TOOL_HTTP_RETRIEVAL_BASE_URL=http://127.0.0.1:8000
# CHAT_TOOL_HTTP_INCIDENTS_BASE_URL=http://127.0.0.1:8000
# CHAT_TOOL_HTTP_TELEMETRY_BASE_URL=http://127.0.0.1:8000

# Token pricing used to estimate llm_cost_usd on chat assistant messages.
# Prices are USD per 1K tokens for the selected chat model.
# LLM_CHAT_INPUT_COST_PER_1K_TOKENS_USD=0.0
# LLM_CHAT_OUTPUT_COST_PER_1K_TOKENS_USD=0.0

# === RAG Ingestion (upload/chunking) ===
# RAG_CHUNK_SIZE_CHARS=1200
# RAG_CHUNK_OVERLAP_CHARS=200
# RAG_UPLOAD_MAX_BYTES=10485760
# RAG_INDEX_BATCH_SIZE=50

# === Logging Configuration ===
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
