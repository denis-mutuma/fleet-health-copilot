# Fleet Health Orchestrator Configuration
# Copy this file to .env and fill in real values for your environment

# === API Configuration ===
# API_TITLE=Fleet Health Orchestrator
# API_VERSION=0.1.0

# === CORS Configuration ===
# Leave empty for no CORS, or provide comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Database Configuration ===
# DATABASE_URL is preferred for PostgreSQL in production
# DATABASE_URL=postgresql://fleet_health:change-me@localhost:5432/fleet_health
# DATABASE_PATH is auto-generated from package structure, but can be overridden
# DATABASE_PATH=/path/to/fleet_health.db

# === Retrieval Backend Configuration ===
RETRIEVAL_BACKEND=lexical

# For S3 Vectors backend (optional):
# RETRIEVAL_BACKEND=s3vectors
# S3_VECTORS_BUCKET=my-vectors-bucket
# S3_VECTORS_INDEX=my-index
# S3_VECTORS_EMBEDDING_DIMENSION=384
# S3_VECTORS_QUERY_VECTOR_JSON=[]

# === Embedding Configuration ===
EMBEDDING_PROVIDER=hash
# Options: hash, openai, http, sentence_transformers

# Add OPENAI_API_KEY to auto-enable OpenAI-backed diagnosis/planning helpers.
# When OPENAI_API_KEY is present and EMBEDDING_PROVIDER is left as hash, the
# orchestrator prefers OpenAI embeddings automatically.
# OPENAI_API_KEY=sk_test_...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === LLM Enrichment (optional) ===
# Enable LLM-assisted summary refinement (requires OPENAI_API_KEY).
# If omitted, the orchestrator will still use OpenAI when the key is present.
# LLM_REPORT_REFINE_ENABLED=false
# LLM_REPORT_MODEL=gpt-4o-mini

# Enable LLM-assisted diagnosis hypothesis enrichment (requires OPENAI_API_KEY)
# LLM_DIAGNOSIS_ENRICH_ENABLED=false
# LLM_DIAGNOSIS_MODEL=gpt-4o-mini

# === Logging Configuration ===
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
